##Quick Sort

#include <stdio.h>
#include <stdlib.h>
#include <time.h>
void swap(int *a,int *b)
{
    int t=*a;
    *a=*b;
    *b=t;
}

int part(int arr[],int low,int high)
{
    int pivot=arr[low];
    int i=low+1;
    int j=high;
    while(i<=j)
    {
        while(arr[i]<=pivot && i<=j)
        {
            i++;
        }
        while(arr[j]>pivot)
        {
            j--;
        }
        if(i<j)
        {
            swap(&arr[i],&arr[j]);
        }
    }
    swap(&arr[low],&arr[j]);
    return j;
}

void quick(int arr[],int low,int high)
{
    if(low < high)
    {
        int p=part(arr,low,high);
        quick(arr,low,p-1);
        quick(arr,p+1,high);
    }
}



